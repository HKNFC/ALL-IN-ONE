# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://verdent:password@localhost:5432/verdent_db?schema=public"

# ── Redis (optional — used for indicator/scan result caching) ─────────────────
# Leave empty to disable Redis; in-process Map cache will be used instead.
REDIS_URL="redis://localhost:6379"

# ── Market Data APIs ──────────────────────────────────────────────────────────

# Twelve Data — birincil veri kaynağı (BIST + US, ücretli plan önerilir)
# https://twelvedata.com/apikey
TWELVE_DATA_API_KEY=""

# Alpha Vantage — yedek kaynak: 5 calls/min, 500 calls/day (ücretsiz)
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=""

# Polygon.io — free tier: 5 API calls/min (US equities)
# https://polygon.io/dashboard/api-keys
POLYGON_API_KEY=""

# İş Yatırım (BIST data)
# Contact https://www.isyatirim.com.tr for API access
IS_YATIRIM_API_KEY=""

# Bigpara (BIST data — alternative source)
BIGPARA_API_KEY=""

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_USE_RANDOM_64_BYTE_HEX"
JWT_EXPIRES_IN="7d"

# ── Frontend (CORS) ───────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"

# ── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
HEAVY_LIMIT_MAX_REQUESTS=10
